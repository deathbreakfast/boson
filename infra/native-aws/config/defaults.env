# Native AWS campaign defaults for Boson Scylla E2E.
BOSON_NATIVE_AWS_REGION="${BOSON_NATIVE_AWS_REGION:-us-west-2}"
# Legacy single-type default (used when bench/broker types unset).
BOSON_NATIVE_AWS_INSTANCE_TYPE="${BOSON_NATIVE_AWS_INSTANCE_TYPE:-t3.medium}"
# Photon-aligned split: c6i.large bench + t3.medium broker (see run-tier3-c6i-aws.sh).
BOSON_BENCH_INSTANCE_TYPE="${BOSON_BENCH_INSTANCE_TYPE:-${BOSON_NATIVE_AWS_INSTANCE_TYPE}}"
BOSON_BROKER_INSTANCE_TYPE="${BOSON_BROKER_INSTANCE_TYPE:-${BOSON_NATIVE_AWS_INSTANCE_TYPE}}"
BOSON_NATIVE_BUILDER_INSTANCE_TYPE="${BOSON_NATIVE_BUILDER_INSTANCE_TYPE:-c7i.xlarge}"
BOSON_NATIVE_AWS_KEY_NAME="${BOSON_NATIVE_AWS_KEY_NAME:-continuum-bench}"
BOSON_NATIVE_AWS_KEY_PATH="${BOSON_NATIVE_AWS_KEY_PATH:-$HOME/.ssh/continuum-bench.pem}"
BOSON_NATIVE_AWS_SG_NAME="${BOSON_NATIVE_AWS_SG_NAME:-boson-bench-sg}"
BOSON_NATIVE_AWS_PROJECT_TAG="${BOSON_NATIVE_AWS_PROJECT_TAG:-boson-bench}"
BOSON_NATIVE_AWS_EBS_GB="${BOSON_NATIVE_AWS_EBS_GB:-20}"
BOSON_NATIVE_AWS_EBS_BUILDER_GB="${BOSON_NATIVE_AWS_EBS_BUILDER_GB:-40}"
BOSON_NATIVE_AMI_X86_FILTER="Name=name,Values=al2023-ami-2023*-kernel-6.1-x86_64 Name=state,Values=available"
BOSON_NATIVE_SCYLLA_IMAGE="${BOSON_NATIVE_SCYLLA_IMAGE:-scylladb/scylla:6.2}"
